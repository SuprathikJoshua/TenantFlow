{
  "compilerOptions": {
    // 1. Environment & Target (Matches Roadmap "ES2022 target" )
    "lib": ["ESNext"],
    "target": "ES2022",
    "module": "CommonJS", 
    "moduleResolution": "Node", 
    "esModuleInterop": true,
    
    // 2. Clean Imports Configuration (Required by Roadmap )
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // 3. Output Settings
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    // 4. Strictness (Matches Roadmap "Strict mode enabled" )
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    // Optional: useful for backend debugging
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
}

